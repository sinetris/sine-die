{{- $author := dict }}
{{- if reflect.IsMap site.Params.author }}
  {{- $author = site.Params.author }}
{{- else if site.Params.author }}
  {{- $author = dict "name" site.Params.author }}
{{- end }}

{{- $siteTaxonomies := slice }}
{{- range $k, $_ := site.Taxonomies }}
  {{- $siteTaxonomies = $siteTaxonomies | append $k }}
{{- end }}

{{- $pctx := . }}
{{- $pages := slice }}
{{- if or .IsHome .IsSection }}
  {{- $pages = .RegularPagesRecursive }}
{{- else }}
  {{- $pages = .Pages }}
{{- end }}
{{- $limit := site.Config.Services.RSS.Limit }}
{{- if ge $limit 1 }}
  {{- $pages = $pages | first $limit }}
{{- end }}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<feed xmlns="http://www.w3.org/2005/Atom">
  {{- $pageTitle := "" }}
  {{- if $pctx.IsHome }}
    {{- $pageTitle = site.Title }}
  {{- else }}
    {{- $pageTitle = printf "%s on %s" $pctx.Title site.Title }}
  {{ end }}
  <title>{{ $pageTitle }}</title>
  <id>
    {{- with .OutputFormats.Get "HTML" -}}
      {{- .Permalink -}}
    {{- else -}}
      {{- .Permalink -}}
    {{- end -}}
  </id>
  {{- with $.OutputFormats.Get "atom" }}
  {{
    printf `<link href=%q rel="self" type=%q hreflang=%q title=%q />`
      .Permalink .MediaType.Type $pctx.Language.LanguageCode $pageTitle
    | safeHTML
  }}
  {{- end }}
  {{- range .AllTranslations }}
    {{- $page := .Page }}
    {{- $linkPageTitle := "" }}
    {{- if $pctx.IsHome }}
      {{- $linkPageTitle = site.Title }}
    {{- else }}
      {{- $linkPageTitle = printf "%s on %s" $page.Title site.Title }}
    {{ end }}
    {{- range .OutputFormats }}
      {{- $linkRel := .Rel }}
      {{- if eq $linkRel "canonical" }}{{ $linkRel = "alternate" }}{{ end }}
      {{
        printf `<link href=%q rel=%q type=%q hreflang=%q title=%q />`
          .Permalink $linkRel .MediaType.Type $page.Language.LanguageCode $linkPageTitle
        | safeHTML
      }}
    {{- end }}
  {{- end }}
  <subtitle>Recent content {{ if not $pctx.IsHome }}{{ with .Title }}in {{ . }} {{ end }}{{ end }}on {{ site.Title }}</subtitle>
  <generator uri="https://github.com/sinetris/sine-die/">Sine Die theme for Hugo</generator>
  {{- with $author }}
  <author>
    {{- with .name }}
    <name>{{.}}</name>
    {{- end }}
    {{- with .email }}
    <email>{{.}}</email>
    {{- end }}
    {{- with .uri }}
    <uri>{{.}}</uri>
    {{- end }}
  </author>
  {{- end }}
  {{- $copyright := "" }}
  {{- with site.Copyright }}
    {{- $copyright = . }}
  {{- else }}
    {{- $copyright = "&copy;" }}
    {{- with site.Params.copyrightStartYear }}
     {{- $copyright = printf "%s %s -" $copyright . }}
    {{- end }}
    {{- $copyright = printf "%s %v, %s" $copyright now.Year $author.name }}
  {{- end }}
  {{- with $copyright }}
  <rights type="html">{{ . }}</rights>
  {{- end }}
  {{- if not .Date.IsZero }}
  <updated>{{ (index $pages.ByLastmod.Reverse 0).Lastmod.Format "2006-01-02T15:04:05Z" | safeHTML }}</updated>
  {{- end }}
  {{- range $pages }}
  <entry>
    {{- $page := . }}
    {{- $entryAuthor := dict }}
    {{- if reflect.IsMap .Params.author }}
      {{- $entryAuthor = .Params.author }}
    {{- else if .Params.author }}
      {{- $entryAuthor = dict "name" .Params.author }}
    {{- end }}
    <title>{{ .Title }}</title>
    {{- with .OutputFormats.Get "html" }}
    {{
      printf `<link href=%q rel="alternate" type=%q hreflang=%q title=%q />`
        .Permalink .MediaType.Type $pctx.Language.LanguageCode $pageTitle
      | safeHTML
    }}
    {{- end }}
    {{- with .OutputFormats.Get "html" }}
      {{
        printf `<content src=%q type=%q />`
          .Permalink .MediaType.Type
        | safeHTML
      }}
    {{- end }}
    <published>{{ .PublishDate.Format "2006-01-02T15:04:05-07:00" | safeHTML }}</published>
    <updated>{{ .Lastmod.Format "2006-01-02T15:04:05Z" | safeHTML }}</updated>
    {{- with $entryAuthor }}
    <author>
      {{- with .name }}
      <name>{{.}}</name>
      {{- end }}
      {{- with .email }}
      <email>{{.}}</email>
      {{- end }}
      {{- with .uri }}
      <uri>{{.}}</uri>
      {{- end }}
    </author>
    {{- end }}
    <id>{{ .Permalink }}#atom</id>
    {{- $summary := .Summary | default (.Description | markdownify) | safeHTML}}
    {{- if .Truncated }}
      {{- with try ($summary | transform.HTMLToMarkdown | markdownify) -}}
        {{- with .Err -}}
          {{- errorf "Error in Atom feed. Unable to parse truncated summary for page %q\n\tSummary: %s" $page.Path $summary -}}
        {{- else with .Value -}}
          {{- $summary = . }}
        {{- end -}}
      {{- end -}}
    {{- end }}
    {{- with $summary }}
    <summary type="html">{{ $summary | transform.XMLEscape | safeHTML }}</summary>
    {{- end }}
    {{- with $page.Type | singularize }}
      <category term="/types/{{ . }}" label="type: {{ . }}" />
    {{- end }}
    {{- range $siteTaxonomies }}
      {{- $taxonomy := . }}
      {{- range $page.Page.GetTerms $taxonomy }}
        <category term="{{ .Path }}" label="{{ $taxonomy | singularize }}: {{ .LinkTitle  }}" />
      {{- end }}
    {{- end }}
  </entry>
  {{- end }}
</feed>
